{
  "mcpServers": {
    "codedb": {
      "command": "codedb",
      "args": [
        "mcp",
        "serve",
        "--repo-path",
        ".",
        "--store",
        ".codedb/store.redb",
        "--default-limit",
        "50",
        "--max-bytes",
        "65536"
      ],
      "env": {}
    }
  },
  "codedbPolicy": {
    "access": "read_only",
    "bounded": true,
    "defaultRowLimit": 50,
    "maxBytes": 65536,
    "rawSourceDefault": "disabled",
    "unsafeBuildCapture": "blocked_in_mcp",
    "mutation": "forbidden",
    "auth": "external_official_codex_auth_only",
    "notes": "Launch from the repository root with the profile-owned codedb command on PATH. For PostgreSQL, use --store pg plus explicit CODEDB_PG_CONN in the process environment; never put credentials in this file."
  }
}
